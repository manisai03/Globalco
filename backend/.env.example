# MySQL (local or production)
SPRING_PROFILES_ACTIVE=mysql
DATABASE_URL=jdbc:mysql://localhost:3306/jobboard?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DATABASE_USERNAME=root
DATABASE_PASSWORD=your-mysql-password

# Email OTP — local dev (SMTP via mail-local.yml)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-gmail-app-password
MAIL_FROM=your-email@gmail.com

# Email OTP — Render/production (Brevo HTTP API; SMTP port 587 is blocked on Render free tier)
BREVO_API_KEY=your-brevo-api-key

# Set before starting backend (PowerShell):
# $env:MAIL_USERNAME="your-email@gmail.com"
# $env:MAIL_PASSWORD="your-16-char-app-password"
